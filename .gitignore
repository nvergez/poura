# Captures BLE / logs bruts — peuvent contenir des données santé + clés. NE PAS committer.
captures/*
!captures/.gitkeep
*.btsnoop
*.pcap
*.pcapng
*.cfa

# Secrets extraits (auth_key, bonds, DBs de l'app Oura) — JAMAIS dans git
*.realm
*.sqlite
secrets/
*.key
auth_key*

# Xcode / Swift
*.xcuserstate
xcuserdata/
DerivedData/
.build/
.swiftpm/
*.xcworkspace/xcuserdata/

# macOS
.DS_Store

# APK / outils RE (volumineux, redistribution firmware Oura à éviter)
*.apk
*.so
*.dex
ble-explorer/.build/
captures/*bugreport*

# Shared PouraCore package (used by both ble-explorer and ios-app)
PouraCore/.build/
PouraCore/.build-ios/

# iOS app: the .xcodeproj AND Info.plist are generated from ios-app/project.yml by XcodeGen.
ios-app/*.xcodeproj
ios-app/PouraApp/PouraApp/Info.plist
ios-app/.build-xcode/

# Local-only RE artifacts and large/generated outputs — keep out of the repo.
research/jadx-out/
research/*decompile*.log
research/oura-apk/
*.smali

# Claude Code harness internal artifacts (not part of the project)
.claude/scheduled_tasks.lock
.claude/*.lock
